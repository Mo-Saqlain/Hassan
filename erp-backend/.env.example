# ──────────────────────────────────────────────────────────
# ERP Backend configuration
# Copy to .env and fill in values. Never commit .env to git.
# ──────────────────────────────────────────────────────────

# HTTP port (default 3001)
PORT=3001

# ─── Database ───────────────────────────────────────────────
# Leave DATABASE_URL blank to use local SQLite (file-based, offline-first).
# When set, the backend switches to Postgres (Supabase or self-hosted).
# DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@db.<project>.supabase.co:5432/postgres

# Path to the SQLite file (only when DATABASE_URL is blank). Default: erp.sqlite
# SQLITE_PATH=erp.sqlite

# When using Postgres, set DB_SYNC=true on first run to auto-create tables;
# afterwards prefer running migrations and leaving this off.
# DB_SYNC=false
# DB_SSL=true

# ─── Cloud sync ─────────────────────────────────────────────
# Set this on the LOCAL (desktop) node to point at the cloud node's /sync/push.
# When set, the Sync button in the topbar pushes pending outbox events.
# Leave blank on the cloud node itself.
# CLOUD_SYNC_URL=https://erp-cloud.example.com/api/sync/push

# HMAC auth for /sync/push. Required on BOTH sides — the local node refuses
# to push if these are unset, and the cloud receiver refuses to accept
# anything without a valid signature.
#
#   SHOP_ID           — short identifier of the shop sending events (e.g. "hassan-main").
#                       The cloud rejects pushes whose X-Shop-Id header does not match.
#   SHOP_SYNC_SECRET  — 32+ random bytes (hex or base64) shared between the local node
#                       and the cloud receiver. Generate with:
#                       node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Never commit SHOP_SYNC_SECRET. Rotate by changing it on both sides at once.
# SHOP_ID=hassan-main
# SHOP_SYNC_SECRET=
